---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="About" description="Learn more about me">
	<main class="bg-bg-dark min-h-screen py-16">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			{/* Header */}
			<div class="mb-12">
				<div class="flex items-center gap-3">
					<Icon name="mdi:account" class="text-4xl md:text-5xl text-text-highlight"></Icon>
					<h1 class="text-4xl md:text-5xl font-bold text-text-header">About</h1>
				</div>
			</div>

			{/* Content Sections */}
			<div class="space-y-8">
				{/* Bio Section */}
				<section class="bg-bg-card border border-border-dim rounded-lg p-8">
					<h2 class="text-2xl font-bold text-text-header mb-4">Background</h2>
					<div class="space-y-4 text-text-dim leading-relaxed">
						<p>
							I'm Michael M, a developer and student with a passion for building solutions to complex problems. I'm currently studying computer science and have a deep interest in systems development and data science.
						</p>
						<p>
							My journey into programming started with curiosity about how things work. I've since developed strong skills in multiple programming languages and frameworks, always striving to write clean, maintainable code that makes a real impact.
						</p>
						<p>
							Beyond coding, I'm an avid snowboarder and a fan of robotics. These hobbies keep me grounded and provide a nice balance to my technical pursuits. I believe in continuous learning and pushing myself to explore new technologies and methodologies.
						</p>
					</div>
				</section>

				{/* Skills Section */}
				<section class="bg-bg-card border border-border-dim rounded-lg p-8">
					<h2 class="text-2xl font-bold text-text-header mb-6">Skills & Technologies</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div>
							<h3 class="text-text-highlight font-semibold mb-3">Languages</h3>
							<div class="flex flex-wrap gap-2">
								{['Python', 'TypeScript', 'JavaScript', 'C', 'Java'].map((skill) => (
									<span class="px-3 py-1 bg-border-dim text-text-dim rounded-lg text-sm font-medium hover:bg-accent hover:text-bg-dark transition-colors">
										{skill}
									</span>
								))}
							</div>
						</div>

						<div>
							<h3 class="text-text-highlight font-semibold mb-3">Web Development</h3>
							<div class="flex flex-wrap gap-2">
								{['Astro', 'React', 'Tailwind CSS', 'Node.js'].map((skill) => (
									<span class="px-3 py-1 bg-border-dim text-text-dim rounded-lg text-sm font-medium hover:bg-accent hover:text-bg-dark transition-colors">
										{skill}
									</span>
								))}
							</div>
						</div>

						<div>
							<h3 class="text-text-highlight font-semibold mb-3">Systems & Tools</h3>
							<div class="flex flex-wrap gap-2">
								{['Windows', 'MacOS', 'Git', 'Docker', 'Visual Studio Code'].map((skill) => (
									<span class="px-3 py-1 bg-border-dim text-text-dim rounded-lg text-sm font-medium hover:bg-accent hover:text-bg-dark transition-colors">
										{skill}
									</span>
								))}
							</div>
						</div>

						<div>
							<h3 class="text-text-highlight font-semibold mb-3">Data Science</h3>
							<div class="flex flex-wrap gap-2">
								{['Machine Learning', 'Data Analysis', 'Pandas', 'NumPy'].map((skill) => (
									<span class="px-3 py-1 bg-border-dim text-text-dim rounded-lg text-sm font-medium hover:bg-accent hover:text-bg-dark transition-colors">
										{skill}
									</span>
								))}
							</div>
						</div>
					</div>
				</section>

				{/* Experience Section */}
				<section class="bg-bg-card border border-border-dim rounded-lg p-8">
					<h2 class="text-2xl font-bold text-text-header mb-6">Experience & Education</h2>
					<div class="space-y-6">
						<div class="border-l-4 border-accent pl-6 py-2">
							<h3 class="text-text-header font-semibold text-lg">Computer Science Student</h3>
							<p class="text-text-highlight text-sm font-medium">University</p>
							<p class="text-text-dim mt-2">Currently pursuing my degree in computer science with focus on systems and data science</p>
						</div>

						<div class="border-l-4 border-accent pl-6 py-2">
							<h3 class="text-text-header font-semibold text-lg">Competitive Programmer</h3>
							<p class="text-text-highlight text-sm font-medium">Algorithms & Problem Solving</p>
							<p class="text-text-dim mt-2">Actively solving algorithmic challenges and participating in programming competitions</p>
						</div>
					</div>
				</section>

				{/* Interests Section */}
				<section class="bg-bg-card border border-border-dim rounded-lg p-8">
					<h2 class="text-2xl font-bold text-text-header mb-6">Interests & Hobbies</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-text-dim">
						<div class="flex items-center gap-3">
							<span class="text-2xl">🏂</span>
							<p><strong>Photos</strong> - I should take more photos of this</p>
						</div>
						<div class="flex items-center gap-3">
							<span class="text-2xl">🤖</span>
							<p><strong>Robotics</strong> - Building and programming robots</p>
						</div>
						<div class="flex items-center gap-3">
							<span class="text-2xl">💻</span>
							<p><strong>Open Source</strong> - Contributing to community projects</p>
						</div>
						<div class="flex items-center gap-3">
							<span class="text-2xl">🧩</span>
							<p><strong>Problem Solving</strong> - Algorithmic and creative challenges</p>
						</div>
					</div>
				</section>
			</div>
		</div>
	</main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import ImageGallery from '../components/ImageGallery.astro';
import { Icon } from 'astro-icon/components';

// Define the Photos images
const images = [
	{
		url: '/snowboardTracking/Slopes 20260114 Mount St. Louis Moonstone Runs and Lifts.png',
		caption: 'Mount St. Louis Moonstone - Jan 14, 2026',
		date: 'Jan 14, 2026',
	},
];
---

<Layout title="Photos" description="Photos photos and videos">
	<main class="bg-bg-dark min-h-screen py-16">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			{/* Header */}
			<div class="mb-12">
				<div class="flex items-center gap-3 mb-4">
					<Icon name="mdi:camera" class="text-4xl md:text-5xl text-text-highlight"></Icon>
					<h1 class="text-4xl md:text-5xl font-bold text-text-header">Photos</h1>
				</div>
				<p class="text-lg text-text-dim max-w-2xl">
					My snowboarding tracking and photos.
				</p>
			</div>

			{/* Gallery */}
			<ImageGallery images={images} />
		</div>
	</main>
</Layout>

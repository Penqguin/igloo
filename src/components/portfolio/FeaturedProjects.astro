---
import { Icon } from 'astro-icon/components';
import { projects } from '../../navigation';

const featuredProjects = projects.filter((p) => p.featured);
---

<section class="bg-[#2E3440] py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Section Header */}
    <div class="mb-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-[#E5E9F0] mb-2">Featured Projects</h2>
          <p class="text-[#D8DEE9] max-w-2xl">Highlighted projects I'm proud of</p>
        </div>
        <a
          href="/projects"
          class="text-[#88C0D0] hover:text-[#81A1C1] transition-colors duration-200 font-medium"
        >
          View all →
        </a>
      </div>
    </div>

    {/* Projects Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map((project) => (
        <div 
          data-project-name={project.name}
          class="group bg-[#3B4252] border border-[#434C5E] rounded-2xl hover:border-[#88C0D0] transition-all duration-300 flex flex-col h-full shadow-md hover:shadow-2xl hover:shadow-[#88C0D0]/10 cursor-pointer"
        >
          {/* Thumbnail with padding */}
          <div class="p-5">
            <div class="overflow-hidden rounded-xl">
              <img 
                src={project.image} 
                alt={project.title}
                class="w-full h-full rounded-xl"
              />
            </div>
          </div>

          {/* Content */}
          <div class="px-8 pb-8 flex flex-col flex-grow">
            {/* Title and Date */}
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-2xl font-bold text-[#E5E9F0] group-hover:text-[#88C0D0] transition-colors">
                {project.title}
              </h3>
              <span class="text-sm text-[#D8DEE9] opacity-60 italic">{project.date}</span>
            </div>

            {/* Description */}
            <p class="text-[#D8DEE9] text-base leading-relaxed mb-6 flex-grow">
              {project.description}
            </p>

            {/* Tags with Icon */}
            <div class="flex items-center gap-3 mt-auto">
              <Icon name="mdi:tag" class="w-5 h-5 text-[#88C0D0] shrink-0" />
              <div class="flex flex-wrap gap-x-4 gap-y-2">
                {project.tags.map((tag) => (
                  <span class="text-xs text-[#88C0D0] font-semibold tracking-wider uppercase">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            {/* GitHub Link */}
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 text-sm text-[#88C0D0] hover:text-[#81A1C1] transition-colors font-bold"
            >
              <Icon name="mdi:github" class="w-5 h-5" />
              View on GitHub
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

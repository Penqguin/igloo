---
import { footerData } from '../../navigation';
import "../../styles/global.css";
import { Icon } from 'astro-icon/components';

const { contentLinks } = footerData;
---

<footer class="bg-[#3B4252] border-t border-[#434C5E] mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-sm">
      <!-- Left side: Social & Copyright -->
      <div class="flex items-center gap-6 text-[#D8DEE9]">
        <span class="hidden md:inline text-[#434C5E]">|</span>
        <p class="opacity-75">&copy; 2025 Michael M</p>
      </div>

      <!-- Right side: Status & Visitors & Attribution -->
      <div class="flex flex-col md:flex-row items-center gap-6 text-[#D8DEE9]">
        
        <span class="hidden md:inline text-[#434C5E]">|</span>
        
        <div class="flex items-center gap-4">
          {contentLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[#88C0D0] transition-colors duration-200"
              aria-label={link.text}
            >
              <Icon name={link.logo} class="w-5 h-5" />
            </a>
          ))}
          <span class="hidden md:inline text-[#434C5E]">|</span>
          <p class="opacity-75">Visitors: <span id="visitorCount" class="font-mono text-[#88C0D0]">...</span></p>
        </div>
      </div>
    </div>
  </div>
</footer>

<script is:inline define:vars={{ isDev: import.meta.env.DEV }}>
  async function updateVisitorCount() {
    try {
      // Use /get in dev mode to avoid incrementing the counter
      const endpoint = isDev ? 'get' : 'hit';
      const res = await fetch(`https://abacus.jsn.cam/${endpoint}/igloo/site-visits`);
      const data = await res.json();
      const visitorCountEl = document.getElementById('visitorCount');
      if (visitorCountEl) {
        visitorCountEl.textContent = data.value.toLocaleString();
      }
    } catch (e) {
      console.error('Failed to update visitor count', e);
    }
  }
  updateVisitorCount();
</script>

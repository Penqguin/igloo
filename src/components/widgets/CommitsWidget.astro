---
import { Icon } from 'astro-icon/components';
---

<div class="bg-bg-card border border-border-dim rounded-lg p-6 hover:border-accent transition-colors duration-200 lg:col-span-2">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base font-semibold text-text-header">Recent Commits</h3>
    <a href="https://github.com/penqguin" target="_blank" rel="noopener noreferrer" class="text-text-highlight hover:text-accent-hover transition-colors">
      <Icon name="mdi:github" class="w-4 h-4" />
    </a>
  </div>

  <div id="commitsList" class="space-y-3 text-xs max-h-48 overflow-y-auto"></div>

  <!-- Language Distribution Bar (client-rendered) -->
  <div id="languageBarContainer" class="relative mt-4 pt-3 border-t border-border-dim hidden">
    <div id="languageBar" class="flex gap-0.5 h-2 rounded overflow-hidden"></div>
    <div id="languageTooltip" style="display:none;" class="absolute -top-7 left-0 text-xs px-2 py-1 rounded bg-bg-dark text-[var(--color-nord-6)] shadow-sm pointer-events-none z-50"></div>
    <div id="languageLegend" class="hidden"></div>
  </div>

  <a href="https://github.com/penqguin" target="_blank" rel="noopener noreferrer" class="text-text-highlight hover:text-accent-hover text-xs mt-3 inline-block">
    View on GitHub →
  </a>
</div>

<script is:inline>
  window.loadCommitsAndLanguages = async function loadCommitsAndLanguages() {
    const commitsList = document.getElementById('commitsList');
    const barContainer = document.getElementById('languageBarContainer');
    const barEl = document.getElementById('languageBar');
    const legendEl = document.getElementById('languageLegend');

    try {
      const apiUrl = 'https://katib.jasoncameron.dev/v2/commits/latest?username=Penqguin';
      const response = await fetch(apiUrl);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const data = await response.json();
      const commits = data.commits || [];
      const languages = data.languages || [];

      if (commits.length === 0) {
        commitsList.innerHTML = '<p class="text-text-highlight">No recent commits found.</p>';
        return;
      }

      // Display top 3 commits
      commitsList.innerHTML = '';
      const displayCommits = commits.slice(0, 3);
      
      for (const commit of displayCommits) {
        const msg = commit.messageHeadline;
        const sha = commit.oid.substring(0, 7);

        const a = document.createElement('a');
        a.href = commit.commitUrl;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'block hover:text-text-highlight transition-colors border-l-2 border-accent pl-3 py-1';

        const p1 = document.createElement('p');
        p1.className = 'text-text-dim hover:underline font-medium';
        p1.textContent = `${commit.repo}: ${msg.substring(0, 40)}`;

        const p2 = document.createElement('p');
        p2.className = 'text-text-highlight text-xs';
        p2.textContent = sha;

        a.appendChild(p1);
        a.appendChild(p2);
        commitsList.appendChild(a);
      }

      // Language Distribution Bar
      if (languages.length > 0) {
        barEl.innerHTML = '';
        legendEl.innerHTML = '';

        const totalSize = languages.reduce((acc, lang) => acc + lang.size, 0);

        // tooltip element (for styled hover info)
        const tooltip = document.getElementById('languageTooltip');

        for (const lang of languages) {
          const color = lang.color || 'var(--color-accent)';
          const pct = (lang.size / totalSize) * 100;

          const seg = document.createElement('div');
          seg.className = 'h-full cursor-pointer';
          seg.style.width = `${pct}%`;
          seg.style.backgroundColor = color;
          seg.dataset.name = lang.name;
          seg.dataset.pct = `${Math.round(pct)}`;
          barEl.appendChild(seg);

          // show styled tooltip on hover
          seg.addEventListener('mouseenter', (ev) => {
            if (!tooltip) return;
            tooltip.textContent = `${seg.dataset.name}: ${seg.dataset.pct}%`;
            tooltip.style.display = 'block';
          });

          seg.addEventListener('mousemove', (ev) => {
            if (!tooltip) return;
            const barRect = barEl.getBoundingClientRect();
            const x = Math.min(Math.max(ev.clientX - barRect.left, 8), barRect.width - 8);
            tooltip.style.left = `${x}px`;
            tooltip.style.transform = 'translateX(-50%)';
          });

          seg.addEventListener('mouseleave', () => {
            if (!tooltip) return;
            tooltip.style.display = 'none';
          });
        }

        barContainer.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Failed to load commits:', err);
      commitsList.innerHTML = '<p class="text-text-highlight">Unable to load recent commits.</p>';
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', window.loadCommitsAndLanguages);
  } else {
    window.loadCommitsAndLanguages();
  }
</script>

---
---

<div class="bg-bg-card border border-border-dim rounded-lg p-6 hover:border-accent transition-colors duration-200 flex flex-col items-center justify-center">
  <div class="text-center mb-4">
    <p class="text-lg font-semibold text-text-header mb-2">Contact Me</p>
    <p class="text-text-dim text-xs mb-4">Always happy to talk about interesting topics.</p>
  </div>

  <form id="contactForm" class="w-full space-y-3">
    <input
      type="email"
      name="email"
      placeholder="Your email"
      class="w-full px-3 py-2 bg-bg-dark border border-border-dim rounded text-text-dim text-xs placeholder-text-highlight focus:outline-none focus:border-accent transition-colors"
    />
    <textarea
      name="message"
      placeholder="Your message"
      rows="3"
      class="w-full px-3 py-2 bg-bg-dark border border-border-dim rounded text-text-dim text-xs placeholder-text-highlight focus:outline-none focus:border-accent transition-colors resize-none"
    ></textarea>
    <button
      type="button"
      disabled
      class="w-full px-3 py-2 bg-accent text-bg-dark rounded text-xs font-semibold opacity-50 cursor-not-allowed"
    >
      Coming Soon
    </button>
  </form>
</div>

---
// Image gallery component
interface Props {
  images: Array<{
    url: string;
    caption?: string;
    date?: string;
  }>;
}

const { images } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-max">
  {images.map((item) => (
    <figure class="bg-bg-card rounded-lg overflow-hidden border border-border-dim hover:border-accent transition-all duration-200 group">
      <img
        src={item.url}
        alt={item.caption}
        class="w-full h-auto"
      />
      {item.caption && (
        <figcaption class="p-4 text-text-dim text-sm border-t border-border-dim">
          <p class="font-medium">{item.caption}</p>
          {item.date && (
            <p class="text-text-highlight text-xs mt-1">{item.date}</p>
          )}
        </figcaption>
      )}
    </figure>
  ))}
</div>

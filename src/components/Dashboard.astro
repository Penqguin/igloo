---
import MapWidget from './widgets/MapWidget.astro';
import CommitsWidget from './widgets/CommitsWidget.astro';
import TicTacToeWidget from './widgets/TicTacToeWidget.astro';
---

<section class="bg-bg-dark py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-text-header mb-12">Dashboard / Highlights</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <CommitsWidget />
      <MapWidget />
      <TicTacToeWidget />
    </div>
  </div>
</section>
